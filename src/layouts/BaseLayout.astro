---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = [
  { href: "/", label: "Dashboard" },
  { href: "/library", label: "My Plants" },
  { href: "/friends", label: "Friends" },
  { href: "/leaderboard", label: "Leaderboard" },
  { href: "/profile", label: "Profile" },
  { href: "/about", label: "About" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#059669" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gradient-to-b from-emerald-50 via-slate-50 to-lime-50 text-slate-900">
    <header class="border-b border-emerald-100 bg-white/90 backdrop-blur">
      <div
        class="mx-auto flex max-w-3xl items-center justify-between gap-3 px-4 py-3"
      >
        <div class="flex items-center gap-3 md:hidden">
          <details class="relative">
            <summary class="flex min-h-11 min-w-11 cursor-pointer list-none items-center justify-center rounded-xl border border-slate-200 bg-slate-50 text-slate-700 shadow-sm">
              <span class="sr-only">Open menu</span>
              <svg
                viewBox="0 0 24 24"
                class="h-6 w-6 fill-none stroke-current stroke-2"
                aria-hidden="true"
              >
                <path d="M4 7h16" />
                <path d="M4 12h16" />
                <path d="M4 17h16" />
              </svg>
            </summary>
            <nav class="absolute left-0 top-14 z-20 w-56 rounded-2xl border border-slate-200 bg-white p-2 shadow-lg">
              {
                nav.map((item) => (
                  <a
                    href={item.href}
                    class={`block rounded-xl px-3 py-3 text-sm ${
                      currentPath === item.href
                        ? "bg-emerald-600 text-white"
                        : "text-slate-700 hover:bg-slate-100"
                    }`}
                  >
                    {item.label}
                  </a>
                ))
              }
            </nav>
          </details>

          <a href="/" class="text-lg font-semibold tracking-tight text-emerald-700">
            PlantsImpact
          </a>
        </div>

        <a
          href="/"
          class="hidden text-lg font-semibold tracking-tight text-emerald-700 md:block"
        >
          PlantsImpact
        </a>

        <nav class="hidden flex-wrap gap-2 md:flex">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class={`rounded-md px-3 py-2 text-sm ${
                  currentPath === item.href
                    ? "bg-emerald-600 text-white"
                    : "text-slate-700 hover:bg-slate-100"
                }`}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-4 sm:py-6">
      <slot />
    </main>

    <footer class="mt-8 border-t border-emerald-100 bg-white/70 pb-safe">
      <div class="mx-auto max-w-3xl px-4 py-4 text-center sm:pr-4 pr-28">
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSc_fNXbHLLRoxT_B48V9kUEDpVdnmLdccT2892nRMQLymm3Ig/viewform?usp=publish-editor"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm font-medium text-emerald-700 transition hover:bg-emerald-100"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4 fill-none stroke-current stroke-2 shrink-0" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
          </svg>
          Help us improve PlantsImpact
          <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current stroke-2 shrink-0 opacity-60" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
            <polyline points="15 3 21 3 21 9" />
            <line x1="10" y1="14" x2="21" y2="3" />
          </svg>
        </a>
        <p class="mt-1.5 text-xs text-slate-400">Part of an RE/UCD university research project</p>
      </div>
    </footer>
  </body>
</html>
