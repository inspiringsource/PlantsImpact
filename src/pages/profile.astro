---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="PlantsImpact | Profile">
  <section class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">Profile</h1>
    <p class="mt-2 text-slate-700">
      Static settings mockup for the university MVP.
    </p>
  </section>

  <section class="space-y-4">
    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center gap-4">
        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-emerald-100 text-2xl font-semibold text-emerald-700">
          A
        </div>
        <div>
          <h2 class="text-lg font-semibold text-slate-900">Avi</h2>
          <p class="text-sm text-slate-600">Student demo account</p>
        </div>
      </div>
    </article>

    <article class="space-y-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div>
        <label class="mb-2 block text-sm font-medium text-slate-700" for="profile-name">
          Display name
        </label>
        <input
          id="profile-name"
          value="Avi"
          class="min-h-11 w-full rounded-xl border border-slate-300 px-3"
        />
      </div>

      <div class="flex items-center justify-between gap-3 rounded-xl bg-slate-50 p-3">
        <div>
          <p class="font-medium text-slate-900">Push notifications</p>
          <p class="text-sm text-slate-600">Reminders for watering and new scans</p>
        </div>
        <div class="flex h-7 w-12 items-center rounded-full bg-emerald-500 px-1">
          <div class="h-5 w-5 rounded-full bg-white" />
        </div>
      </div>

      <div class="flex items-center justify-between gap-3 rounded-xl bg-slate-50 p-3">
        <div>
          <p class="font-medium text-slate-900">Public profile</p>
          <p class="text-sm text-slate-600">Show your plant count in the leaderboard</p>
        </div>
        <div class="flex h-7 w-12 items-center rounded-full bg-slate-300 px-1">
          <div class="ml-auto h-5 w-5 rounded-full bg-white" />
        </div>
      </div>

      <button
        type="button"
        class="min-h-11 w-full rounded-xl bg-emerald-600 text-sm font-semibold text-white"
      >
        Save settings
      </button>
    </article>
  </section>
</BaseLayout>
