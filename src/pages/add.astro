---
import AddAssetForm from "../components/AddAssetForm";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="PlantsImpact | Add Plant">
  <section class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">
      Add a plant
    </h1>
    <p class="mt-2 text-slate-700">
      Add your green assets to include them in estimated impact and your
      personal plant list.
    </p>
  </section>

  <AddAssetForm client:load />
</BaseLayout>
