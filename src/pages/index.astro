---
import DashboardApp from "../components/DashboardApp";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="PlantsImpact | Dashboard">
  <section class="mb-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">
      Small actions, long-term effect
    </p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-950">
      PlantsImpact
    </h1>
    <p class="mt-2 max-w-2xl text-slate-700">
      Add a plant, view your personal plant list, and see estimated long-term
      impact across 1, 2, 5, and 10 years.
    </p>
  </section>

  <DashboardApp client:load />
</BaseLayout>
