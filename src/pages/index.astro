---
import DashboardApp from "../components/DashboardApp";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="PlantsImpact | Dashboard">
  <section class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900">
      Track your positive impact
    </h1>
    <p class="mt-2 text-slate-700">
      Add your plants and instantly see clearer, human-friendly climate and
      neighborhood benefits across 2, 5, 10, and 20 years.
    </p>
  </section>

  <DashboardApp client:load />
</BaseLayout>
